---
import Layout from '../layouts/Layout.astro';
import { loadAllTrips, worldPoints } from '@lib/trips';

const trips = loadAllTrips();
---

<Layout title="Exile">
  <div class="page" id="page" data-trips={JSON.stringify(trips)}>

    <!-- Sidebar: always visible -->
    <aside class="sidebar">
      <header>
        <h1>exile</h1>
        <p class="tagline">places I've been</p>
      </header>

      <nav>
        <button class="world-btn" id="world-btn">world map</button>
        <ul>
          {trips.map(trip => (
            <li>
              <button class="trip-btn" data-slug={trip.slug}>
                <span class="trip-title">{trip.title}</span>
                <span class="trip-date">{trip.date_start.slice(0, 4)}</span>
              </button>
              {trip.description && (
                <p class="trip-desc">{trip.description}</p>
              )}
            </li>
          ))}
          {trips.length === 0 && (
            <li class="empty">No trips yet. Add one in <code>trips/</code>.</li>
          )}
        </ul>
      </nav>
    </aside>

    <!-- Globe: single persistent instance -->
    <div class="globe-area">
      <div id="globe-target"></div>
      <div id="globe-tooltip" aria-hidden="true"></div>
    </div>

    <!-- Content panel: always visible, empty until a trip is selected -->
    <div class="content-panel" id="content-panel">
      <div class="panel-back" id="panel-back" style="display:none">
        <button class="back-btn" id="back-btn">← all trips</button>
      </div>

      {trips.map(trip => (
        <div class="trip-content" data-slug={trip.slug} style="display:none">
          <header class="trip-header">
            <h2>{trip.title}</h2>
            <p class="dates">
              {trip.date_start}
              {trip.date_end && trip.date_end !== trip.date_start && (
                <> — {trip.date_end}</>
              )}
            </p>
            {trip.description && <p class="description">{trip.description}</p>}
          </header>

          <div class="photo-roll">
            {trip.stops.map((stop, i) => (
              <div class="roll-stop" data-stop={stop.name}>
                <div class="stop-label">
                  <span class="stop-index">{String(i + 1).padStart(2, '0')}</span>
                  <span class="stop-name">{stop.name}</span>
                  {stop.date_start && (
                    <span class="stop-date">
                      {stop.date_start}{stop.date_end && stop.date_end !== stop.date_start ? ` — ${stop.date_end}` : ''}
                    </span>
                  )}
                </div>

                {stop.note && <p class="stop-note">{stop.note}</p>}

                {stop.images && stop.images.length > 0 && (
                  <div class="roll-frames">
                    {stop.images.map((img, imgIdx) => (
                      <figure class="roll-frame">
                        <a href={`/trips/${trip.slug}/images/${img}`} target="_blank" rel="noopener">
                          <img
                            src={`/trips/${trip.slug}/images/${img}`}
                            alt={stop.name}
                            loading="lazy"
                          />
                        </a>
                        <figcaption>
                          <span class="frame-location">{stop.name}</span>
                          <span class="frame-meta">
                            {stop.date_start && <span>{stop.date_start}{stop.date_end && stop.date_end !== stop.date_start ? ` — ${stop.date_end}` : ''}</span>}
                            <span class="frame-num">{String(imgIdx + 1).padStart(2, '0')}/{String(stop.images!.length).padStart(2, '0')}</span>
                          </span>
                        </figcaption>
                      </figure>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>

<script>
  import Globe from 'globe.gl';

  const page = document.getElementById('page')!;
  const trips: Array<{
    slug: string;
    title: string;
    stops: Array<{ name: string; lat: number; lon: number; date?: string }>;
  }> = JSON.parse(page.dataset.trips!);

  // ---- polygon helpers ----

  type Pt = [number, number]; // [lon, lat]

  function cross(O: Pt, A: Pt, B: Pt): number {
    return (A[0] - O[0]) * (B[1] - O[1]) - (A[1] - O[1]) * (B[0] - O[0]);
  }

  function convexHull(pts: Pt[]): Pt[] {
    if (pts.length < 2) return pts;
    const s = [...pts].sort((a, b) => a[0] - b[0] || a[1] - b[1]);
    const lower: Pt[] = [];
    for (const p of s) {
      while (lower.length >= 2 && cross(lower[lower.length - 2], lower[lower.length - 1], p) <= 0) lower.pop();
      lower.push(p);
    }
    const upper: Pt[] = [];
    for (let i = s.length - 1; i >= 0; i--) {
      const p = s[i];
      while (upper.length >= 2 && cross(upper[upper.length - 2], upper[upper.length - 1], p) <= 0) upper.pop();
      upper.push(p);
    }
    lower.pop(); upper.pop();
    return [...lower, ...upper];
  }

  function expandHull(hull: Pt[], pad: number): Pt[] {
    const cx = hull.reduce((s, p) => s + p[0], 0) / hull.length;
    const cy = hull.reduce((s, p) => s + p[1], 0) / hull.length;
    return hull.map(p => {
      const dx = p[0] - cx, dy = p[1] - cy;
      const len = Math.sqrt(dx * dx + dy * dy) || 0.001;
      return [cx + (dx / len) * (len + pad), cy + (dy / len) * (len + pad)] as Pt;
    });
  }

  function tripPolygonCoords(stops: Array<{ lat: number; lon: number }>, pad = 2): Pt[] {
    const pts: Pt[] = stops.map(s => [s.lon, s.lat]);
    if (pts.length === 1) {
      const [lon, lat] = pts[0];
      // CW winding — d3-geo renders the enclosed small area for CW exterior rings
      const ring = Array.from({ length: 32 }, (_, i) => {
        const a = -(i / 32) * Math.PI * 2;
        return [lon + Math.cos(a) * pad, lat + Math.sin(a) * pad] as Pt;
      });
      return [...ring, ring[0]];
    }
    const hull = convexHull(pts);
    const expanded = expandHull(hull.length >= 3 ? hull : pts, pad);
    // Reverse to CW — globe.gl/d3-geo renders the enclosed small area for CW exterior rings
    expanded.reverse();
    return [...expanded, expanded[0]];
  }

  // ---- build data (once) ----

  type GlobePoint = { name: string; lat: number; lon: number; tripSlug: string; days: number };
  type GlobePoly  = { tripSlug: string; tripTitle: string; geometry: object };

  function stopDays(stop: { date_start?: string; date_end?: string }): number {
    if (!stop.date_start) return 1;
    const start = new Date(stop.date_start).getTime();
    const end   = stop.date_end ? new Date(stop.date_end).getTime() : start;
    return Math.max(1, Math.round((end - start) / 86400000) + 1);
  }

  // All stops across all trips (deduplicated by lat/lon)
  const stopPoints: GlobePoint[] = [];
  const seenKeys = new Set<string>();
  for (const t of trips) {
    for (const s of t.stops) {
      const key = `${s.lat},${s.lon}`;
      if (!seenKeys.has(key)) {
        stopPoints.push({ name: s.name, lat: s.lat, lon: s.lon, tripSlug: t.slug, days: stopDays(s) });
        seenKeys.add(key);
      }
    }
  }

  const maxDays = Math.max(1, ...stopPoints.map(p => p.days));

  // ---- point size animation ----

  let animFromSlug: string | null = null;
  let animToSlug:   string | null = null;
  let animProgress  = 1;
  let animFrame:    number | null = null;

  function easeInOut(t: number): number {
    return t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
  }

  function pointScale(p: GlobePoint): number {
    const fromScale = (animFromSlug !== null && p.tripSlug === animFromSlug) ? 1 : 0.5;
    const toScale   = (animToSlug   !== null && p.tripSlug === animToSlug)   ? 1 : 0.5;
    return fromScale + (toScale - fromScale) * easeInOut(animProgress);
  }

  function stopAltitude(p: GlobePoint): number {
    return (0.03 + (p.days / maxDays) * 0.35) * pointScale(p);
  }

  function stopRadius(p: GlobePoint): number {
    return 0.2 * pointScale(p);
  }

  function animatePoints(toSlug: string | null) {
    animFromSlug = currentSlug;
    animToSlug   = toSlug;
    animProgress = 0;
    if (animFrame) cancelAnimationFrame(animFrame);
    const start = performance.now();
    const DURATION = 450;
    function tick() {
      animProgress = Math.min(1, (performance.now() - start) / DURATION);
      globe.pointAltitude((p: object) => stopAltitude(p as GlobePoint));
      globe.pointRadius((p: object) => stopRadius(p as GlobePoint));
      if (animProgress < 1) animFrame = requestAnimationFrame(tick);
      else animFrame = null;
    }
    tick();
  }

  // Polygons: one per trip covering all stops
  const polygons: GlobePoly[] = trips.map(t => ({
    tripSlug: t.slug,
    tripTitle: t.title,
    geometry: { type: 'Polygon', coordinates: [tripPolygonCoords(t.stops)] },
  }));

  // ---- state ----

  let currentSlug: string | null = null;

  function pointColor(p: GlobePoint): string {
    return (!currentSlug || p.tripSlug !== currentSlug) ? '#ffffff' : '#e8d5b0';
  }

  function polyFill(p: GlobePoly): string {
    return p.tripSlug === currentSlug ? 'rgba(200,169,126,0.07)' : 'rgba(255,255,255,0.02)';
  }

  function polyStroke(p: GlobePoly): string {
    return p.tripSlug === currentSlug ? 'rgba(200,169,126,0.75)' : 'rgba(255,255,255,0.2)';
  }

  // ---- globe ----

  const tooltip = document.getElementById('globe-tooltip')!;

  function showTooltip(text: string) { tooltip.textContent = text; tooltip.classList.add('visible'); }
  function hideTooltip() { tooltip.classList.remove('visible'); }

  const globe = Globe()
    .globeImageUrl('//unpkg.com/three-globe/example/img/earth-dark.jpg')
    .backgroundImageUrl('')
    .backgroundColor('rgba(0,0,0,1)')
    .pointsData(stopPoints)
    .pointLat('lat')
    .pointLng('lon')
    .pointLabel('name')
    .pointColor((p: object) => pointColor(p as GlobePoint))
    .pointAltitude((p: object) => stopAltitude(p as GlobePoint))
    .pointRadius((p: object) => stopRadius(p as GlobePoint))
    // trip polygons
    .polygonsData(polygons)
    .polygonGeoJsonGeometry('geometry')
    .polygonCapColor((p: object) => polyFill(p as GlobePoly))
    .polygonSideColor(() => 'rgba(0,0,0,0)')
    .polygonStrokeColor((p: object) => polyStroke(p as GlobePoly))
    .polygonAltitude(0.001)
    // arcs (populated on selection)
    .arcsData([])
    .arcStartLat('startLat')
    .arcStartLng('startLng')
    .arcEndLat('endLat')
    .arcEndLng('endLng')
    .arcColor(() => '#c8a97e')
    .arcAltitudeAutoScale(0.4)
    .arcDashLength(0.4)
    .arcDashGap(0.2)
    .arcDashAnimateTime(2000)
    // interactions
    .onPointClick((point: object) => {
      const p = point as GlobePoint;
      selectTrip(p.tripSlug);
    })
    .onPointHover((point: object | null) => {
      const p = point as GlobePoint | null;
      if (p) {
        const trip = trips.find(t => t.slug === p.tripSlug);
        showTooltip(trip?.title ?? p.name);
      } else {
        hideTooltip();
      }
    })
    .onPolygonClick((poly: object) => {
      selectTrip((poly as GlobePoly).tripSlug);
    })
    .onPolygonHover((poly: object | null) => {
      const p = poly as GlobePoly | null;
      if (p) showTooltip(p.tripTitle);
      else hideTooltip();
    })(document.getElementById('globe-target')!);

  globe.controls().autoRotate = true;
  globe.controls().autoRotateSpeed = 0.3;
  globe.controls().enableDamping = true;

  new ResizeObserver(() => {
    const el = document.getElementById('globe-target')!;
    globe.width(el.clientWidth).height(el.clientHeight);
  }).observe(document.getElementById('globe-target')!);

  // ---- select / deselect ----

  function selectTrip(slug: string) {
    const trip = trips.find(t => t.slug === slug);
    if (!trip) return;

    currentSlug = slug;

    // Update globe
    globe.pointColor((p: object) => pointColor(p as GlobePoint));
    globe.polygonCapColor((p: object) => polyFill(p as GlobePoly));
    globe.polygonStrokeColor((p: object) => polyStroke(p as GlobePoly));
    animatePoints(currentSlug);
    const arcs = trip.stops.slice(0, -1).map((s, i) => ({
      startLat: s.lat, startLng: s.lon,
      endLat: trip.stops[i + 1].lat, endLng: trip.stops[i + 1].lon,
    }));
    globe.arcsData(arcs);
    globe.controls().autoRotate = false;

    if (trip.stops.length > 0) {
      const lats = trip.stops.map(s => s.lat);
      const lons = trip.stops.map(s => s.lon);
      globe.pointOfView({
        lat: (Math.min(...lats) + Math.max(...lats)) / 2,
        lng: (Math.min(...lons) + Math.max(...lons)) / 2,
        altitude: 2,
      }, 1000);
    }

    // Show content
    document.querySelectorAll<HTMLElement>('.trip-content').forEach(el => {
      el.style.display = el.dataset.slug === slug ? 'flex' : 'none';
    });
    document.getElementById('panel-back')!.style.display = 'block';
    document.getElementById('content-panel')!.scrollTop = 0;

    // Sidebar active state
    document.querySelectorAll('.trip-btn').forEach(b => b.classList.remove('active'));
    document.querySelector<HTMLElement>(`.trip-btn[data-slug="${slug}"]`)?.classList.add('active');

    history.pushState(null, '', `#/trips/${slug}`);
  }

  function deselectTrip() {
    currentSlug = null;

    // Reset globe
    globe.pointColor((p: object) => pointColor(p as GlobePoint));
    globe.polygonCapColor((p: object) => polyFill(p as GlobePoly));
    globe.polygonStrokeColor((p: object) => polyStroke(p as GlobePoly));
    animatePoints(currentSlug);
    globe.arcsData([]);
    globe.controls().autoRotate = true;

    // Hide content
    document.querySelectorAll<HTMLElement>('.trip-content').forEach(el => {
      el.style.display = 'none';
    });
    document.getElementById('panel-back')!.style.display = 'none';

    // Sidebar
    document.querySelectorAll('.trip-btn').forEach(b => b.classList.remove('active'));

    history.pushState(null, '', location.pathname);
  }

  // ---- event listeners ----

  document.querySelectorAll<HTMLElement>('.trip-btn').forEach(btn => {
    btn.addEventListener('click', () => selectTrip(btn.dataset.slug!));
  });

  document.getElementById('back-btn')!.addEventListener('click', deselectTrip);
  document.getElementById('world-btn')!.addEventListener('click', deselectTrip);

  window.addEventListener('popstate', () => {
    const match = location.hash.match(/^#\/trips\/(.+)/);
    if (match) selectTrip(match[1]);
    else deselectTrip();
  });

  // Initial load
  const initial = location.hash.match(/^#\/trips\/(.+)/);
  if (initial) selectTrip(initial[1]);
</script>

<style>
  .page {
    display: grid;
    grid-template-columns: 280px 1fr 440px;
    height: 100vh;
    overflow: hidden;
  }

  /* ---- sidebar ---- */

  .sidebar {
    padding: 2rem 1.5rem;
    border-right: 1px solid var(--border);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    background: var(--surface);
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .tagline {
    font-size: 0.8rem;
    color: var(--muted);
    margin-top: 0.25rem;
  }

  .world-btn {
    all: unset;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--border-bright);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: block;
    transition: color 0.15s;
  }

  .world-btn:hover {
    color: var(--text);
  }

  nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .trip-btn {
    all: unset;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    width: 100%;
    cursor: pointer;
    color: var(--text);
    font-weight: 500;
    font-size: 0.95rem;
  }

  .trip-btn:hover,
  .trip-btn.active {
    color: var(--accent);
  }

  .trip-date {
    font-size: 0.75rem;
    color: var(--muted);
    font-family: var(--font-mono);
    flex-shrink: 0;
  }

  .trip-desc {
    font-size: 0.8rem;
    color: var(--muted);
    margin-top: 0.25rem;
    line-height: 1.4;
  }

  .empty {
    font-size: 0.85rem;
    color: var(--muted);
  }

  /* ---- globe ---- */

  .globe-area {
    height: 100vh;
    overflow: hidden;
    background: var(--bg);
    position: relative;
  }

  #globe-target {
    width: 100%;
    height: 100%;
  }

  #globe-tooltip {
    position: absolute;
    top: 1rem;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(10, 9, 8, 0.85);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.4rem 0.8rem;
    font-size: 0.85rem;
    color: var(--text);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
    white-space: nowrap;
    backdrop-filter: blur(8px);
  }

  #globe-tooltip.visible {
    opacity: 1;
  }

  /* ---- content panel ---- */

  .content-panel {
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    border-left: 1px solid var(--border);
    background: var(--surface);
  }

  .panel-back {
    padding: 1rem 1.75rem 0;
    flex-shrink: 0;
  }

  .back-btn {
    all: unset;
    cursor: pointer;
    font-size: 0.75rem;
    color: var(--muted);
    font-family: var(--font-mono);
  }

  .back-btn:hover {
    color: var(--text);
  }

  /* ---- trip content / photo roll ---- */

  .trip-content {
    flex-direction: column;
    flex: 1;
  }

  .trip-header {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem 1.75rem;
    border-bottom: 1px solid var(--border);
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--text);
  }

  .dates {
    font-size: 0.72rem;
    color: var(--muted);
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  .description {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.55;
    margin-top: 0.25rem;
  }

  .photo-roll {
    display: flex;
    flex-direction: column;
    padding-bottom: 6rem;
  }

  .roll-stop {
    display: flex;
    flex-direction: column;
    scroll-margin-top: 1rem;
  }

  .stop-label {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 1.25rem 1.75rem 0.6rem;
  }

  .stop-index {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent-warm);
    flex-shrink: 0;
    letter-spacing: 0.05em;
  }

  .stop-name {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .stop-date {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--muted);
    margin-left: auto;
    flex-shrink: 0;
  }

  .stop-note {
    font-size: 0.83rem;
    color: var(--muted);
    line-height: 1.6;
    padding: 0 1.75rem 0.75rem;
  }

  .roll-frames {
    display: flex;
    flex-direction: column;
  }

  .roll-frame {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border);
  }

  .roll-frame a {
    display: block;
    overflow: hidden;
    background: #000;
  }

  .roll-frame img {
    width: 100%;
    display: block;
    object-fit: cover;
    transition: opacity 0.3s ease;
    opacity: 0.92;
  }

  .roll-frame a:hover img {
    opacity: 1;
  }

  .roll-frame figcaption {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.45rem 1.75rem;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }

  .frame-location {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .frame-meta {
    display: flex;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.03em;
  }

  .frame-num {
    color: var(--border-bright);
  }

  /* ---- responsive ---- */

  @media (max-width: 900px) {
    .page {
      grid-template-columns: 280px 1fr;
      grid-template-rows: 1fr auto;
    }

    .content-panel {
      grid-column: 1 / -1;
      border-left: none;
      border-top: 1px solid var(--border);
      max-height: 50vh;
    }
  }
</style>
