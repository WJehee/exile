---
import type { Trip } from '@lib/trips';

interface Props {
  trip: Trip;
}

const { trip } = Astro.props;
---

<div id="trip-globe-root" data-trip={JSON.stringify(trip)}>
  <div id="trip-globe"></div>
</div>

<script>
  import Globe from 'globe.gl';

  const root = document.getElementById('trip-globe-root')!;
  const trip: {
    stops: Array<{ name: string; lat: number; lon: number }>;
  } = JSON.parse(root.dataset.trip!);

  const stops = trip.stops;

  // Build arcs between consecutive stops
  const arcs = stops.slice(0, -1).map((stop, i) => ({
    startLat: stop.lat,
    startLng: stop.lon,
    endLat: stops[i + 1].lat,
    endLng: stops[i + 1].lon,
  }));

  const globe = Globe()
    .globeImageUrl('//unpkg.com/three-globe/example/img/earth-dark.jpg')
    .backgroundImageUrl('//unpkg.com/three-globe/example/img/night-sky.png')
    .pointsData(stops)
    .pointLat('lat')
    .pointLng('lon')
    .pointLabel('name')
    .pointColor(() => '#f7934f')
    .pointAltitude(0.015)
    .pointRadius(0.5)
    .arcsData(arcs)
    .arcStartLat('startLat')
    .arcStartLng('startLng')
    .arcEndLat('endLat')
    .arcEndLng('endLng')
    .arcColor(() => '#4f8ef7')
    .arcAltitudeAutoScale(0.4)
    .arcDashLength(0.4)
    .arcDashGap(0.2)
    .arcDashAnimateTime(2000)
    .onPointClick((point: object) => {
      const p = point as { name: string };
      // Scroll to the matching stop section
      const el = document.querySelector(`[data-stop="${CSS.escape(p.name)}"]`);
      el?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    })(document.getElementById('trip-globe')!);

  globe.controls().autoRotate = false;
  globe.controls().enableDamping = true;

  // Fly to fit all stops
  if (stops.length > 0) {
    const lats = stops.map(s => s.lat);
    const lons = stops.map(s => s.lon);
    const centerLat = (Math.min(...lats) + Math.max(...lats)) / 2;
    const centerLon = (Math.min(...lons) + Math.max(...lons)) / 2;
    globe.pointOfView({ lat: centerLat, lng: centerLon, altitude: 2 }, 0);
  }

  const resizeObserver = new ResizeObserver(() => {
    const el = document.getElementById('trip-globe')!;
    globe.width(el.clientWidth).height(el.clientHeight);
  });
  resizeObserver.observe(document.getElementById('trip-globe')!);
</script>

<style>
  #trip-globe-root {
    width: 100%;
    height: 100%;
  }

  #trip-globe {
    width: 100%;
    height: 100%;
  }
</style>
